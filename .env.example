# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in your own keys.
#   cp .env.example .env.local
#
# `.env.local` is gitignored — your keys stay on your machine.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Providers ─────────────────────────────────────────────────────────────
# At least ONE of the two below is required for the review-generation feature.
# If both are set, Gemini is used first and MiniMax is the automatic fallback.

# Google Gemini — https://aistudio.google.com/apikey (free tier works fine)
VITE_GEMINI_API_KEY=

# MiniMax (optional fallback) — https://www.minimax.io/platform
MINIMAX_API_KEY=

# ── Database: Turso (libSQL) ─────────────────────────────────────────────────
# Required. Free hobby tier is plenty.
# 1. Sign up at https://turso.tech
# 2. Create a database, then run:  turso db show <name> --url
# 3. Mint a token:                 turso db tokens create <name>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Cloudflare R2 (optional) ─────────────────────────────────────────────────
# Only needed if you want the in-app gallery image upload feature.
# Leave blank to skip — the rest of the app still works.
# Create an R2 bucket + API token: https://dash.cloudflare.com → R2 → Manage API Tokens
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# ── Server ───────────────────────────────────────────────────────────────────
# Optional. Defaults to 3005.
PORT=3005
